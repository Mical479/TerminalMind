---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const configPath = '/home/ubuntu/my_knowledge';
  const interviewPath = path.join(process.cwd(), 'public', 'content', 'interview');
  const contentPath = fs.existsSync(interviewPath) ? interviewPath : path.join(process.cwd(), 'public/content/interview');
  
  const paths: { params: { slug: string }; props: { title: string; questions: any[]; breadcrumb: string } }[] = [];

  function walk(dir: string, baseSlug: string = '') {
    if (!fs.existsSync(dir)) return;

    const items = fs.readdirSync(dir, { withFileTypes: true });

    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      const ext = path.extname(item.name).toLowerCase();

      if (item.isDirectory()) {
        walk(fullPath, baseSlug ? `${baseSlug}/${item.name}` : item.name);
      } else if (ext === '.md' || ext === '.mdx') {
        const slug = item.name.replace(/\.mdx?$/, '');
        const fullSlug = baseSlug ? `${baseSlug}/${slug}` : slug;
        const content = fs.readFileSync(fullPath, 'utf-8');
        const titleMatch = content.match(/^#\s+(.+)$/m);
        const title = titleMatch ? titleMatch[1].trim() : slug;

        const questions: any[] = [];
        const questionBlocks = content.split(/^##\s+/m).slice(1);
        
        for (const block of questionBlocks) {
          const lines = block.trim().split('\n');
          const qTitle = lines[0];
          const rest = lines.slice(1).join('\n');
          
          const optionMatches = [...rest.matchAll(/^- ([A-Z])\)\s*(.+)$/gm)];
          const options: any[] = [];
          let correctAnswer: string | null = null;
          
          for (const match of optionMatches) {
            const letter = match[1];
            const text = match[2].replace(/\*\*([^*]+)\*\*/g, '$1').replace('[x]', '').trim();
            options.push({ letter, text });
            
            const originalText = match[2];
            if (originalText.includes('[x]') || originalText.toLowerCase().includes(`correct: ${letter.toLowerCase()}`)) {
              correctAnswer = letter;
            }
          }
          
          const answerMatch = rest.match(/\*\*Answer:\*\*\s*([A-Z])/i) || rest.match(/Answer:\s*([A-Z])/i);
          if (answerMatch && !correctAnswer) {
            correctAnswer = answerMatch[1].toUpperCase();
          }
          
          if (options.length > 0) {
            questions.push({
              question: qTitle,
              options,
              answer: correctAnswer
            });
          }
        }

        paths.push({
          params: { slug: fullSlug },
          props: { 
            title: title.replace(/\[.*?\]$/, '').trim(),
            questions,
            breadcrumb: baseSlug ? baseSlug.split('/').join(' > ') : 'root'
          }
        });
      }
    }
  }

  walk(contentPath);
  return paths;
}

const { title, questions, breadcrumb } = Astro.props;
const totalQuestions = questions.length;
---

<Layout title={title}>
  <div style="max-width: 800px; margin: 0 auto; padding-bottom: 40px;">
    <!-- Back & Title -->
    <div style="margin-bottom: 24px;">
      <a href="/interview" style="color: var(--apple-blue); text-decoration: none; font-size: 14px; display: inline-flex; align-items: center; gap: 4px;">
        ← 返回面试题
      </a>
    </div>

    <!-- Quiz Card -->
    <div class="content-card">
      <div style="padding: 24px; border-bottom: 1px solid var(--apple-border);">
        <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 8px;">{title}</h1>
        <div style="display: flex; align-items: center; gap: 16px; color: var(--text-secondary); font-size: 14px;">
          <span>{totalQuestions} 道题目</span>
          <span>|</span>
          <span id="score-display">得分: 0</span>
        </div>
      </div>

      <!-- Progress -->
      <div style="padding: 16px 24px; border-bottom: 1px solid var(--apple-border);">
        <div style="display: flex; justify-content: space-between; font-size: 13px; color: var(--text-secondary); margin-bottom: 8px;">
          <span>进度</span>
          <span id="progress-text">1 / {totalQuestions}</span>
        </div>
        <div style="background: var(--bg-secondary); height: 6px; border-radius: 3px; overflow: hidden;">
          <div id="progress-bar" style="background: var(--apple-blue); height: 100%; width: 0%; transition: width 0.3s ease;"></div>
        </div>
      </div>

      <!-- Questions Container -->
      <div id="quiz-container" style="padding: 24px;">
        {questions.map((q: any, index: number) => (
          <div 
            class="quiz-question-container"
            data-index={index}
            data-answer={q.answer}
            style={index === 0 ? '' : 'display: none;'}
          >
            <div style="font-size: 16px; font-weight: 500; margin-bottom: 16px; color: var(--text-primary);">
              <span style="color: var(--apple-blue); font-weight: 600;">Q{index + 1}</span>
              <span style="margin-left: 8px;">{q.question}</span>
            </div>
            
            <div class="quiz-options">
              {q.options.map((opt: any) => (
                <div 
                  class="quiz-option" 
                  data-letter={opt.letter}
                >
                  <span style="font-weight: 500; margin-right: 8px; color: var(--apple-blue);">{opt.letter}</span>
                  {opt.text}
                </div>
              ))}
            </div>

            <!-- AI Hint -->
            <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--apple-border);">
              <button 
                class="ai-hint-btn"
                data-question={q.question}
                style="background: var(--bg-secondary); border: 1px solid var(--apple-border); padding: 8px 16px; border-radius: var(--radius-sm); font-size: 14px; cursor: pointer; color: var(--text-secondary); display: inline-flex; align-items: center; gap: 6px;"
              >
                🤖  AI 提示
              </button>
              <div class="ai-hint-result" style="margin-top: 12px; padding: 12px; background: var(--bg-secondary); border-radius: var(--radius-sm); font-size: 14px; display: none;"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation -->
      <div id="quiz-nav" style="padding: 20px 24px; border-top: 1px solid var(--apple-border); display: flex; justify-content: space-between;">
        <button id="prev-btn" class="btn btn-secondary" disabled style="opacity: 0.5;">
          ← 上一题
        </button>
        <button id="next-btn" class="btn btn-primary" disabled style="opacity: 0.5;">
          下一题 →
        </button>
      </div>

      <!-- Complete Screen -->
      <div id="complete-screen" style="padding: 48px; text-align: center; display: none;">
        <div style="font-size: 64px; margin-bottom: 16px;">🎉</div>
        <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 8px;">练习完成！</h2>
        <p style="font-size: 18px; color: var(--text-secondary); margin-bottom: 24px;">
          你的得分: <span id="final-score" style="font-weight: 700; color: var(--apple-blue);">0</span> / {totalQuestions}
        </p>
        <div style="display: flex; gap: 12px; justify-content: center;">
          <a href="/interview" class="btn btn-secondary">返回列表</a>
          <button id="retry-btn" class="btn btn-primary">再试一次</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  interface QuizState {
    currentIndex: number;
    score: number;
    answered: Set<number>;
  }

  const state: QuizState = {
    currentIndex: 0,
    score: 0,
    answered: new Set()
  };

  const questions = document.querySelectorAll('.quiz-question-container');
  const totalQuestions = questions.length;
  const progressBar = document.getElementById('progress-bar')!;
  const progressText = document.getElementById('progress-text')!;
  const scoreDisplay = document.getElementById('score-display')!;
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const completeScreen = document.getElementById('complete-screen')!;
  const quizNav = document.getElementById('quiz-nav')!;
  const finalScore = document.getElementById('final-score')!;
  const retryBtn = document.getElementById('retry-btn')!;

  function showQuestion(index: number) {
    questions.forEach((q, i) => {
      (q as HTMLElement).style.display = i === index ? 'block' : 'none';
    });
    
    progressText.textContent = `${index + 1} / ${totalQuestions}`;
    progressBar.style.width = `${((index + 1) / totalQuestions) * 100}%`;
    
    prevBtn.disabled = index === 0;
    prevBtn.style.opacity = index === 0 ? '0.5' : '1';
    
    const currentQ = questions[index] as HTMLElement;
    const isAnswered = state.answered.has(index);
    nextBtn.disabled = !isAnswered;
    nextBtn.style.opacity = isAnswered ? '1' : '0.5';
    
    nextBtn.textContent = index === totalQuestions - 1 ? '查看结果 →' : '下一题 →';
  }

  function selectAnswer(questionIndex: number, letter: string) {
    if (state.answered.has(questionIndex)) return;
    
    const question = questions[questionIndex] as HTMLElement;
    const answer = question.dataset.answer!;
    const options = question.querySelectorAll('.quiz-option');
    
    state.answered.add(questionIndex);
    
    options.forEach(opt => {
      const optLetter = opt.getAttribute('data-letter')!;
      if (optLetter === answer) {
        opt.classList.add('correct');
      } else if (optLetter === letter && letter !== answer) {
        opt.classList.add('incorrect');
      }
    });
    
    if (letter === answer) {
      state.score++;
      scoreDisplay.textContent = `得分: ${state.score}`;
    }
    
    nextBtn.disabled = false;
    nextBtn.style.opacity = '1';
  }

  function nextQuestion() {
    if (state.currentIndex < totalQuestions - 1) {
      state.currentIndex++;
      showQuestion(state.currentIndex);
    } else {
      showComplete();
    }
  }

  function prevQuestion() {
    if (state.currentIndex > 0) {
      state.currentIndex--;
      showQuestion(state.currentIndex);
    }
  }

  function showComplete() {
    quizNav.style.display = 'none';
    completeScreen.style.display = 'block';
    finalScore.textContent = String(state.score);
  }

  function resetQuiz() {
    state.currentIndex = 0;
    state.score = 0;
    state.answered.clear();
    
    scoreDisplay.textContent = '得分: 0';
    quizNav.style.display = 'flex';
    completeScreen.style.display = 'none';
    
    questions.forEach(q => {
      const options = q.querySelectorAll('.quiz-option');
      options.forEach(opt => {
        opt.classList.remove('correct', 'incorrect');
      });
      const hintResult = q.querySelector('.ai-hint-result') as HTMLElement;
      if (hintResult) hintResult.style.display = 'none';
    });
    
    showQuestion(0);
  }

  questions.forEach((q, index) => {
    const options = q.querySelectorAll('.quiz-option');
    options.forEach(opt => {
      opt.addEventListener('click', () => {
        selectAnswer(index, opt.getAttribute('data-letter')!);
      });
    });
  });

  nextBtn.addEventListener('click', nextQuestion);
  prevBtn.addEventListener('click', prevQuestion);
  retryBtn.addEventListener('click', resetQuiz);

  // AI Hint
  document.querySelectorAll('.ai-hint-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const button = e.target as HTMLButtonElement;
      const question = button.dataset.question!;
      const hintResult = button.nextElementSibling as HTMLElement;
      
      hintResult.style.display = 'block';
      hintResult.textContent = '🤖 思考中...';
      
      try {
        const res = await fetch('/api/ai-hint', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question })
        });
        const data = await res.json();
        hintResult.textContent = `💡 ${data.hint}`;
      } catch {
        hintResult.textContent = '❌ 获取提示失败';
      }
    });
  });

  showQuestion(0);
</script>
