---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const basePath = '/home/ubuntu/my_knowledge/03-面试准备/面试题库';
  const paths = [];

  if (!fs.existsSync(basePath)) return paths;

  const items = fs.readdirSync(basePath, { withFileTypes: true });

  for (const item of items) {
    const fullPath = path.join(basePath, item.name);
    
    if (item.isDirectory()) continue;
    if (item.name.toLowerCase() === 'README.md' || item.name.startsWith('.')) continue;
    
    const ext = path.extname(item.name).toLowerCase();
    if (ext !== '.md' && ext !== '.mdx') continue;
    
    const slug = item.name.replace(/\.mdx?$/, '');
    const content = fs.readFileSync(fullPath, 'utf-8');
    
    // Parse frontmatter
    const match = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    let metadata: Record<string, any> = {};
    let body = content;
    
    if (match) {
      const yamlStr = match[1];
      body = match[2];
      
      yamlStr.split('\n').forEach(line => {
        const [key, ...valueParts] = line.split(':');
        if (key && valueParts.length > 0) {
          const value = valueParts.join(':').trim();
          if (value.startsWith('[') && value.endsWith(']')) {
            metadata[key.trim()] = value.slice(1, -1).split(',').map(s => s.trim());
          } else {
            metadata[key.trim()] = value.replace(/^["']|["']$/g, '');
          }
        }
      });
    }
    
    // Parse knowledge points
    const knowledgePoints: any[] = [];
    const sections = body.split(/^##\s+(.+)$/gm).filter(Boolean);
    
    for (let i = 1; i < sections.length; i += 2) {
      const title = sections[i];
      const contentBlock = sections[i + 1] || '';
      
      // Extract subsections
      const subsections: any[] = [];
      
      // Extract ### subsections
      const subsectionBlocks = contentBlock.split(/^###\s+(.+)$/gm).filter(Boolean);
      for (let j = 1; j < subsectionBlocks.length; j += 2) {
        const subTitle = subsectionBlocks[j];
        const subContent = subsectionBlocks[j + 1] || '';
        
        // Extract lists and Q&A
        const keywords: string[] = [];
        const qas: { q: string; a: string }[] = [];
        
        subContent.split('\n').forEach(line => {
          // Keywords list
          const kwMatch = line.match(/^-\s+(.+)/);
          if (kwMatch) keywords.push(kwMatch[1]);
          
          // Q&A format
          const qaMatch = line.match(/\*\*Q:\s*(.+?)\*\*/);
          if (qaMatch) {
            const question = qaMatch[1];
            const answerLine = line.replace(/\*\*Q:.*?\*\*/, '').replace(/:\s*/, '').trim();
            qas.push({ q: question, a: answerLine || '待补充' });
          }
        });
        
        if (subTitle || keywords.length > 0 || qas.length > 0) {
          subsections.push({
            title: subTitle,
            keywords,
            qas
          });
        }
      }
      
      if (title) {
        knowledgePoints.push({
          title,
          content: contentBlock.replace(/^###\s+.+$/gm, '').replace(/^-\s+/gm, '').trim(),
          subsections
        });
      }
    }

    paths.push({
      params: { slug },
      props: { 
        title: metadata.title || slug,
        metadata,
        knowledgePoints
      }
    });
  }

  return paths;
}

const { title, metadata, knowledgePoints } = Astro.props;

const difficultyConfig: Record<string, { color: string; bg: string; label: string }> = {
  Easy: { color: '#34C759', bg: 'rgba(52, 199, 89, 0.1)', label: '🟢 简单' },
  Medium: { color: '#FF9500', bg: 'rgba(255, 149, 0, 0.1)', label: '🟡 中等' },
  Hard: { color: '#FF3B30', bg: 'rgba(255, 59, 48, 0.1)', label: '🔴 困难' }
};

const diff = difficultyConfig[metadata.difficulty || 'Medium'] || difficultyConfig.Medium;
---

<Layout title={title}>
  <div class="interview-container">
    <!-- Header -->
    <div class="interview-header">
      <a href="/interview" class="back-link">← 返回面试题</a>
      <div class="header-card">
        <div class="header-meta">
          <span class="difficulty-badge" style={`color: ${diff.color}; background: ${diff.bg};`}>
            {diff.label}
          </span>
          {metadata.tags && metadata.tags.map((tag: string) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
        <h1 class="header-title">{title}</h1>
        <div class="header-date">{metadata.date}</div>
      </div>
    </div>

    <!-- Cards Grid -->
    <div class="cards-grid">
      {knowledgePoints.map((kp: any, index: number) => (
        <div class="knowledge-card" data-index={index}>
          <div class="card-header">
            <span class="card-number">{index + 1}</span>
            <h2 class="card-title">{kp.title}</h2>
          </div>
          
          <div class="card-subsections">
            {kp.subsections.map((sub: any) => (
              <div class="subsection">
                {sub.title && <h3 class="subsection-title">{sub.title}</h3>}
                
                {sub.keywords && sub.keywords.length > 0 && (
                  <div class="keywords">
                    {sub.keywords.map((kw: string) => (
                      <span class="keyword">{kw}</span>
                    ))}
                  </div>
                )}
                
                {sub.qas && sub.qas.length > 0 && (
                  <div class="qas">
                    {sub.qas.map((qa: any) => (
                      <div class="qa-item">
                        <span class="qa-q">Q: {qa.q}</span>
                        <span class="qa-a">A: {qa.a}</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
          
          <button class="expand-btn" onclick="toggleCard(this)">
            <span class="expand-text">展开详情</span>
            <svg class="expand-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
        </div>
      ))}
    </div>

    <!-- AI Helper -->
    <div class="ai-helper">
      <p>需要更详细的解释？询问 AI 助手</p>
      <a href="/chat" class="ai-btn">🤖 询问 AI</a>
    </div>
  </div>

  <!-- Floating Card Modal -->
  <div id="card-modal" class="modal" onclick="closeModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="closeModal()">×</button>
      <div class="modal-header">
        <span class="modal-number"></span>
        <h2 class="modal-title"></h2>
      </div>
      <div class="modal-body"></div>
    </div>
  </div>
</Layout>

<script>
  function toggleCard(btn: HTMLButtonElement) {
    const card = btn.closest('.knowledge-card') as HTMLElement;
    const isExpanded = card.classList.contains('expanded');
    
    if (isExpanded) {
      card.classList.remove('expanded');
      btn.querySelector('.expand-text')!.textContent = '展开详情';
    } else {
      card.classList.add('expanded');
      btn.querySelector('.expand-text')!.textContent = '收起详情';
    }
  }

  function openModal(index: number) {
    const cards = document.querySelectorAll('.knowledge-card');
    const card = cards[index] as HTMLElement;
    const modal = document.getElementById('card-modal') as HTMLElement;
    
    const number = card.querySelector('.card-number')!.textContent;
    const title = card.querySelector('.card-title')!.textContent;
    const content = card.querySelector('.card-subsections')!.innerHTML;
    
    modal.querySelector('.modal-number')!.textContent = number;
    modal.querySelector('.modal-title')!.textContent = title;
    modal.querySelector('.modal-body')!.innerHTML = content;
    
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(event?: MouseEvent) {
    if (event && (event.target as HTMLElement).id !== 'card-modal') return;
    const modal = document.getElementById('card-modal') as HTMLElement;
    modal.classList.remove('active');
    document.body.style.overflow = '';
  }

  // Make functions available globally
  (window as any).toggleCard = toggleCard;
  (window as any).openModal = openModal;
  (window as any).closeModal = closeModal;
</script>

<style>
  .interview-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 24px;
    padding-bottom: 80px;
  }

  .interview-header {
    margin-bottom: 32px;
  }

  .back-link {
    display: inline-block;
    color: var(--apple-blue);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 16px;
  }

  .header-card {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--apple-border);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .difficulty-badge {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 600;
  }

  .tag {
    color: var(--text-secondary);
    font-size: 13px;
  }

  .header-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .header-date {
    color: var(--text-secondary);
    font-size: 14px;
  }

  /* Cards Grid */
  .cards-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .knowledge-card {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--apple-border);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .knowledge-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--apple-blue);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--apple-border);
    cursor: pointer;
  }

  .card-number {
    width: 36px;
    height: 36px;
    background: var(--apple-blue);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }

  .card-title {
    font-size: 18px;
    font-weight: 600;
    flex: 1;
  }

  .card-subsections {
    padding: 20px 24px;
    display: none;
  }

  .knowledge-card.expanded .card-subsections {
    display: block;
  }

  .subsection {
    margin-bottom: 20px;
  }

  .subsection:last-child {
    margin-bottom: 0;
  }

  .subsection-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--apple-blue);
    margin-bottom: 12px;
  }

  .keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .keyword {
    background: rgba(0, 122, 255, 0.1);
    color: var(--apple-blue);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 13px;
  }

  .qas {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qa-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px;
    background: var(--bg-secondary);
    border-radius: 8px;
  }

  .qa-q {
    font-weight: 600;
    font-size: 14px;
    color: var(--text-primary);
  }

  .qa-a {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .expand-btn {
    width: 100%;
    padding: 14px;
    background: var(--bg-secondary);
    border: none;
    border-top: 1px solid var(--apple-border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 14px;
    color: var(--apple-blue);
    transition: background 0.2s;
  }

  .expand-btn:hover {
    background: var(--bg-tertiary);
  }

  .expand-icon {
    width: 18px;
    height: 18px;
    transition: transform 0.3s;
  }

  .knowledge-card.expanded .expand-icon {
    transform: rotate(180deg);
  }

  /* AI Helper */
  .ai-helper {
    margin-top: 40px;
    text-align: center;
    padding: 24px;
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--apple-border);
  }

  .ai-helper p {
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .ai-btn {
    display: inline-block;
    padding: 12px 24px;
    background: var(--apple-blue);
    color: white;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-weight: 500;
    transition: background 0.2s;
  }

  .ai-btn:hover {
    background: #0066d6;
  }

  /* Modal */
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .modal.active {
    opacity: 1;
    pointer-events: auto;
  }

  .modal-content {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    max-width: 700px;
    max-height: 80vh;
    width: 90%;
    overflow: hidden;
    transform: translateY(20px);
    transition: transform 0.3s;
    position: relative;
  }

  .modal.active .modal-content {
    transform: translateY(0);
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    border: none;
    background: var(--bg-secondary);
    border-radius: 50%;
    font-size: 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: background 0.2s;
  }

  .modal-close:hover {
    background: var(--apple-border);
  }

  .modal-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--apple-border);
  }

  .modal-number {
    width: 40px;
    height: 40px;
    background: var(--apple-blue);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
  }

  .modal-title {
    font-size: 20px;
    font-weight: 600;
    flex: 1;
  }

  .modal-body {
    padding: 24px;
    overflow-y: auto;
    max-height: calc(80vh - 100px);
  }

  .modal-body .subsection {
    margin-bottom: 24px;
  }

  .modal-body .subsection:last-child {
    margin-bottom: 0;
  }

  .modal-body .keywords {
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .interview-container {
      padding: 16px;
    }

    .header-card {
      padding: 20px;
    }

    .header-title {
      font-size: 22px;
    }

    .card-header {
      padding: 16px;
    }

    .card-title {
      font-size: 16px;
    }
  }
</style>
