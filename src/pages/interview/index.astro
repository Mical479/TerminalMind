---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

interface InterviewEntry {
  title: string;
  slug: string;
  category: string;
  difficulty?: string;
  questions: number;
  path: string;
}

function getAllInterviews(baseDir: string): InterviewEntry[] {
  const interviews: InterviewEntry[] = [];
  
  if (!fs.existsSync(baseDir)) return interviews;
  
  function walk(dir: string, category: string = 'root') {
    const items = fs.readdirSync(dir, { withFileTypes: true });
    
    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      
      if (item.isDirectory()) {
        walk(fullPath, item.name);
      } else {
        const ext = path.extname(item.name).toLowerCase();
        if (ext === '.md' || ext === '.mdx') {
          const slug = item.name.replace(/\.mdx?$/, '');
          const content = fs.readFileSync(fullPath, 'utf-8');
          const titleMatch = content.match(/^#\s+(.+)$/m);
          const title = titleMatch ? titleMatch[1].trim() : slug;
          
          const questionMatches = content.match(/^#{2,3}\s+/gm);
          const questions = questionMatches ? questionMatches.length : 0;
          
          let difficulty: string | undefined;
          const diffMatch = title.match(/\[(.*?)\]$/);
          if (diffMatch) {
            difficulty = diffMatch[1];
          }
          
          interviews.push({
            title: title.replace(/\[.*?\]$/, '').trim(),
            slug,
            category,
            difficulty,
            questions,
            path: fullPath.replace(process.cwd() + '/public/content/', '')
          });
        }
      }
    }
  }
  
  walk(baseDir);
  return interviews;
}

const interviewPath = path.join(process.cwd(), 'public', 'content', 'interview');
const interviews = getAllInterviews(interviewPath);

const grouped = interviews.reduce((acc, interview) => {
  const cat = interview.category || 'uncategorized';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(interview);
  return acc;
}, {} as Record<string, InterviewEntry[]>);

const categories = Object.keys(grouped).sort();

const difficultyColors: Record<string, string> = {
  'easy': 'var(--apple-success)',
  'medium': 'var(--apple-warning)',
  'hard': 'var(--apple-error)'
};
---

<Layout title="面试题">
  <!-- Hero -->
  <div class="hero-card" style="text-align: left; padding: 32px;">
    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
      <span style="font-size: 32px;">🎯</span>
      <div>
        <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 4px;">面试题练习</h1>
        <p style="color: var(--text-secondary); font-size: 15px;">共 {interviews.length} 个话题，{interviews.reduce((sum, i) => sum + i.questions, 0)} 道题目</p>
      </div>
    </div>
    
    <!-- Difficulty Legend -->
    <div style="display: flex; gap: 16px; font-size: 13px;">
      <span style="display: flex; align-items: center; gap: 6px;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--apple-success);"></span>
        Easy
      </span>
      <span style="display: flex; align-items: center; gap: 6px;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--apple-warning);"></span>
        Medium
      </span>
      <span style="display: flex; align-items: center; gap: 6px;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--apple-error);"></span>
        Hard
      </span>
    </div>
  </div>

  <!-- Categories -->
  {categories.map(category => (
    <div class="content-card" style="margin-bottom: 20px;">
      <div style="padding: 16px 20px; border-bottom: 1px solid var(--apple-border); display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 18px;">📋</span>
        <span style="font-weight: 600; font-size: 15px;">{category}</span>
        <span style="color: var(--text-secondary); font-size: 13px; margin-left: auto;">
          {grouped[category].length} 个话题
        </span>
      </div>
      <div style="padding: 12px;">
        {grouped[category].map(interview => (
          <a 
            href={`/interview/${interview.slug}`}
            class="quiz-card"
            style="display: flex; align-items: center; justify-content: space-between; text-decoration: none; margin-bottom: 8px;"
          >
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="font-size: 20px;">📝</span>
              <div>
                <div style="font-weight: 500; color: var(--text-primary);">{interview.title}</div>
                <div style="font-size: 13px; color: var(--text-secondary);">{interview.questions} 道题</div>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              {interview.difficulty && (
                <span 
                  style={`padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: 500; background: ${difficultyColors[interview.difficulty.toLowerCase()] || 'gray'}15; color: ${difficultyColors[interview.difficulty.toLowerCase()] || 'gray'};`}
                >
                  {interview.difficulty}
                </span>
              )}
              <span style="color: var(--apple-blue);">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}

  <!-- Empty state -->
  {interviews.length === 0 && (
    <div class="content-card" style="padding: 48px; text-align: center;">
      <div style="font-size: 48px; margin-bottom: 16px;">📭</div>
      <p style="color: var(--text-secondary);">暂无面试题</p>
      <p style="color: var(--text-secondary); font-size: 14px; margin-top: 8px;">
        将面试题 Markdown 文件添加到 interview 目录即可显示
      </p>
    </div>
  )}
</Layout>
