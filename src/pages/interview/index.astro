---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

interface InterviewEntry {
  title: string;
  slug: string;
  category: string;
  difficulty?: string;
  questions: number;
}

function getAllInterviews(baseDir: string): InterviewEntry[] {
  const interviews: InterviewEntry[] = [];
  
  if (!fs.existsSync(baseDir)) return interviews;
  
  function walk(dir: string, category: string = 'root') {
    const items = fs.readdirSync(dir, { withFileTypes: true });
    
    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      
      if (item.isDirectory()) {
        walk(fullPath, item.name);
      } else {
        const ext = path.extname(item.name).toLowerCase();
        if (ext === '.md' || ext === '.mdx') {
          const slug = item.name.replace(/\.mdx?$/, '');
          const content = fs.readFileSync(fullPath, 'utf-8');
          const titleMatch = content.match(/^#\s+(.+)$/m);
          const title = titleMatch ? titleMatch[1].trim() : slug;
          
          // Count questions (lines starting with ## or ###)
          const questionMatches = content.match(/^#{2,3}\s+/gm);
          const questions = questionMatches ? questionMatches.length : 0;
          
          // Extract difficulty from frontmatter or title
          let difficulty: string | undefined;
          const diffMatch = title.match(/\[(.*?)\]$/);
          if (diffMatch) {
            difficulty = diffMatch[1];
          }
          
          interviews.push({
            title: title.replace(/\[.*?\]$/, '').trim(),
            slug,
            category,
            difficulty,
            questions
          });
        }
      }
    }
  }
  
  walk(baseDir);
  return interviews;
}

const interviewPath = path.join(process.cwd(), 'public', 'content', 'interview');
const interviews = getAllInterviews(interviewPath);

// Group by category
const grouped = interviews.reduce((acc, interview) => {
  const cat = interview.category || 'uncategorized';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(interview);
  return acc;
}, {} as Record<string, InterviewEntry[]>);

const categories = Object.keys(grouped).sort();

const difficultyColors: Record<string, string> = {
  'easy': 'var(--cyber-green)',
  'medium': 'var(--cyber-yellow)',
  'hard': 'var(--cyber-red)'
};
---

<Layout title="Interview Mode">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="terminal-window mt-4 p-6">
      <div class="flex items-center gap-4 mb-4">
        <span style="color: var(--cyber-purple);">🎯</span>
        <h1 class="text-2xl font-bold" style="color: var(--cyber-purple);">Interview Mode</h1>
      </div>
      <p class="opacity-70">Challenge yourself with interview questions. Select a topic below to start practicing!</p>
      
      <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div class="p-3 rounded" style="background: rgba(0,255,159,0.1);">
          <div class="text-xl font-bold" style="color: var(--cyber-green);">{interviews.length}</div>
          <div class="text-xs opacity-60">topics</div>
        </div>
        <div class="p-3 rounded" style="background: rgba(0,212,255,0.1);">
          <div class="text-xl font-bold" style="color: var(--cyber-cyan);">{interviews.reduce((sum, i) => sum + i.questions, 0)}</div>
          <div class="text-xs opacity-60">questions</div>
        </div>
        <div class="p-3 rounded" style="background: rgba(255,255,0,0.1);">
          <div class="text-xl font-bold" style="color: var(--cyber-yellow);">?</div>
          <div class="text-xs opacity-60">your score</div>
        </div>
        <div class="p-3 rounded" style="background: rgba(191,0,255,0.1);">
          <div class="text-xl font-bold" style="color: var(--cyber-purple);">∞</div>
          <div class="text-xs opacity-60">attempts</div>
        </div>
      </div>
    </div>

    <!-- Category Legend -->
    <div class="mt-4 text-sm flex flex-wrap gap-4">
      <span class="flex items-center gap-2">
        <span class="w-3 h-3 rounded" style="background: var(--cyber-green);"></span>
        Easy
      </span>
      <span class="flex items-center gap-2">
        <span class="w-3 h-3 rounded" style="background: var(--cyber-yellow);"></span>
        Medium
      </span>
      <span class="flex items-center gap-2">
        <span class="w-3 h-3 rounded" style="background: var(--cyber-red);"></span>
        Hard
      </span>
    </div>

    <!-- Categories & Interviews -->
    {categories.map(category => (
      <div class="terminal-window mt-6">
        <div class="terminal-header">
          <span class="text-lg" style="color: var(--cyber-yellow);">📁 {category}/</span>
        </div>
        <div class="p-4">
          <div class="grid gap-3">
            {grouped[category].map(interview => (
              <a 
                href={`/interview/${interview.slug}`}
                class="quiz-card flex items-center justify-between"
                style="text-decoration: none;"
              >
                <div class="flex items-center gap-4">
                  <span class="text-2xl">📝</span>
                  <div>
                    <div class="font-medium glow-green">{interview.title}</div>
                    <div class="text-sm opacity-60 mt-1">
                      {interview.questions} questions
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  {interview.difficulty && (
                    <span 
                      class="px-3 py-1 rounded text-xs font-bold uppercase"
                      style={`background: ${difficultyColors[interview.difficulty.toLowerCase()] || 'gray'}20; color: ${difficultyColors[interview.difficulty.toLowerCase()] || 'gray'};`}
                    >
                      {interview.difficulty}
                    </span>
                  )}
                  <span style="color: var(--cyber-green);">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    ))}

    <!-- Empty state -->
    {interviews.length === 0 && (
      <div class="terminal-window mt-6 p-8 text-center">
        <div class="text-4xl mb-4">📭</div>
        <p class="opacity-70">No interview questions found.</p>
        <p class="text-sm mt-2 opacity-50">
          Add markdown files to <code class="px-2 py-1 rounded" style="background: rgba(0,255,159,0.1);">public/content/interview/</code>
        </p>
      </div>
    )}
  </div>
</Layout>
