---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI 对话">
  <div class="chat-container">
    <!-- Chat Header -->
    <div class="chat-header">
      <span style="font-size: 28px;">🤖</span>
      <div>
        <h1 style="font-size: 18px; font-weight: 600;">AI 助手</h1>
        <p style="font-size: 13px; color: var(--text-secondary);">基于知识库的智能问答</p>
      </div>
      <div style="margin-left: auto; display: flex; align-items: center; gap: 8px;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--apple-success);"></span>
        <span style="font-size: 13px; color: var(--text-secondary);" id="status-text">在线</span>
      </div>
    </div>

    <!-- Chat Messages -->
    <div class="chat-messages" id="chat-messages">
      <!-- Welcome Message -->
      <div class="chat-message assistant">
        <span style="font-size: 28px;">🤖</span>
        <div class="chat-bubble">
          <p style="margin-bottom: 12px;">你好！我是你的 AI 助手，可以回答关于知识库的问题，也可以聊聊技术话题。</p>
          <p style="margin-bottom: 8px; font-size: 13px; color: var(--text-secondary);">试试这些问题：</p>
          <ul style="font-size: 13px; color: var(--text-secondary); padding-left: 16px;">
            <li>解释 Spring 的依赖注入</li>
            <li>什么是 Transformer 架构？</li>
            <li>JVM 内存模型是怎样的？</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div style="padding: 12px 24px; border-top: 1px solid var(--apple-border); background: var(--bg-tertiary);">
      <div class="quick-actions">
        <button class="quick-action" data-prompt="解释依赖注入（DI）在 Spring 框架中的实现">
          💉 Spring DI
        </button>
        <button class="quick-action" data-prompt="JVM 和 JRE、JDK 的区别是什么？">
          ☕ JVM vs JRE
        </button>
        <button class="quick-action" data-prompt="解释 Transformer 的注意力机制">
          🧠 Transformer
        </button>
      </div>
    </div>

    <!-- Input Area -->
    <div class="chat-input-area">
      <input 
        type="text" 
        id="chat-input"
        class="chat-input"
        placeholder="输入你的问题..."
      />
      <button id="send-btn" class="btn btn-primary" style="padding: 12px 20px;">
        发送
      </button>
    </div>
  </div>
</Layout>

<script>
  interface Message {
    role: 'user' | 'assistant';
    content: string;
  }

  const messages: Message[] = [];
  const chatMessages = document.getElementById('chat-messages')!;
  const chatForm = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('send-btn')!;

  function addMessage(role: 'user' | 'assistant', content: string) {
    const msgDiv = document.createElement('div');
    msgDiv.className = `chat-message ${role}`;
    
    const icon = role === 'user' ? '👤' : '🤖';
    
    msgDiv.innerHTML = `
      <span style="font-size: 28px;">${icon}</span>
      <div class="chat-bubble">
        <p style="white-space: pre-wrap; line-height: 1.6;">${escapeHtml(content)}</p>
      </div>
    `;
    
    chatMessages.appendChild(msgDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    
    messages.push({ role, content });
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function setStatus(text: string) {
    const statusEl = document.getElementById('status-text');
    if (statusEl) statusEl.textContent = text;
  }

  async function handleSend() {
    const text = chatForm.value.trim();
    if (!text) return;
    
    chatForm.value = '';
    addMessage('user', text);
    setStatus('思考中...');
    sendBtn.disabled = true;
    
    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          messages: messages.concat([{ role: 'user', content: text }])
        })
      });
      
      const data = await res.json();
      
      if (data.error) {
        addMessage('assistant', `错误: ${data.error}`);
      } else {
        addMessage('assistant', data.message);
      }
    } catch {
      addMessage('assistant', '抱歉，遇到了一些问题，请稍后再试。');
    }
    
    sendBtn.disabled = false;
    setStatus('在线');
    chatForm.focus();
  }

  sendBtn.addEventListener('click', handleSend);
  chatForm.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  });

  // Quick actions
  document.querySelectorAll('.quick-action').forEach(btn => {
    btn.addEventListener('click', () => {
      const prompt = (btn as HTMLElement).dataset.prompt!;
      chatForm.value = prompt;
      handleSend();
    });
  });

  chatForm.focus();
</script>
