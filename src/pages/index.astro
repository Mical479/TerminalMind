---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页">
  <!-- Hero Section -->
  <div class="hero-card fade-in">
    <h1 class="hero-title">TerminalMind</h1>
    <p class="hero-subtitle">知识库与面试题练习平台</p>
    <div style="display: flex; gap: 12px; justify-content: center;">
      <a href="/knowledge" class="btn btn-primary">
        📚 开始探索
      </a>
      <a href="/interview" class="btn btn-secondary">
        🎯 面试练习
      </a>
    </div>
  </div>

  <!-- Feature Cards -->
  <div class="features fade-in" style="animation-delay: 0.1s;">
    <a href="/knowledge" class="feature-card">
      <div class="feature-icon">📚</div>
      <div class="feature-title">知识库</div>
      <div class="feature-desc">
        浏览我的知识沉淀，涵盖 Java、AI、架构设计等多个领域
      </div>
      <span class="feature-arrow">→</span>
    </a>

    <a href="/interview" class="feature-card">
      <div class="feature-icon">🎯</div>
      <div class="feature-title">面试题练习</div>
      <div class="feature-desc">
        闯关答题，AI 智能提示，帮你准备面试挑战
      </div>
      <span class="feature-arrow">→</span>
    </a>

    <a href="/chat" class="feature-card">
      <div class="feature-icon">🤖</div>
      <div class="feature-title">AI 助手</div>
      <div class="feature-desc">
        与 AI 对话，解答知识库相关问题，聊天中学习
      </div>
      <span class="feature-arrow">→</span>
    </a>
  </div>

  <!-- Stats -->
  <div class="stats-card fade-in" style="animation-delay: 0.2s;">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-value" id="doc-count">-</div>
        <div class="stat-label">知识文档</div>
      </div>
      <div class="stat-item">
        <div class="stat-value" id="interview-count">-</div>
        <div class="stat-label">面试题目</div>
      </div>
      <div class="stat-item">
        <div class="stat-value" style="color: var(--apple-success);">∞</div>
        <div class="stat-label">学习可能</div>
      </div>
      <div class="stat-item">
        <div class="stat-value" style="color: var(--apple-warning);">100%</div>
        <div class="stat-label">全力以赴</div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="stats-card fade-in" style="animation-delay: 0.3s; margin-top: 24px;">
    <div style="padding: 20px 24px;">
      <div style="font-size: 14px; color: var(--text-secondary); margin-bottom: 16px; font-weight: 500;">
        快捷访问
      </div>
      <div class="quick-actions">
        <a href="/knowledge/AI学习/Agent工程师/1-2026年我决定跟AI死磕" class="quick-action">
          🚀 AI 学习笔记
        </a>
        <a href="/interview/java/jvm-interview" class="quick-action">
          ☕ Java JVM 面试题
        </a>
        <a href="/interview/ai/llm-interview" class="quick-action">
          🤖 LLM 面试题
        </a>
        <a href="/chat" class="quick-action">
          💬 AI 对话
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  async function loadStats() {
    try {
      const res = await fetch('/api/stats');
      const data = await res.json();
      
      const docCount = document.getElementById('doc-count');
      const interviewCount = document.getElementById('interview-count');
      
      if (docCount) docCount.textContent = data.knowledgeCount?.toString() || '0';
      if (interviewCount) interviewCount.textContent = data.interviewCount?.toString() || '0';
    } catch (e) {
      // Silently fail
    }
  }
  
  loadStats();
</script>
