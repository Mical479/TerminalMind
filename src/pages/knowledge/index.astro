---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

interface KnowledgeConfig {
  basePath: string;
  showDirs: string[];
  excludeDirs: string[];
  title: string;
}

interface DocEntry {
  title: string;
  slug: string;
  category: string;
  path: string;
}

// 默认配置
const defaultConfig: KnowledgeConfig = {
  basePath: '/home/ubuntu/my_knowledge',
  showDirs: [],
  excludeDirs: ['.obsidian', '.git', 'Excalidraw', 'Prompt', '公众号'],
  title: '知识库'
};

// 读取配置
function getConfig(): KnowledgeConfig {
  try {
    const configPath = path.join(process.cwd(), 'config', 'site.config.json');
    if (fs.existsSync(configPath)) {
      const configData = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
      return { ...defaultConfig, ...configData.knowledge };
    }
  } catch (e) {
    console.error('Failed to load config:', e);
  }
  return defaultConfig;
}

function getAllDocs(config: KnowledgeConfig): DocEntry[] {
  const docs: DocEntry[] = [];
  const basePath = config.basePath;
  
  if (!fs.existsSync(basePath)) return docs;
  
  function walk(dir: string, category: string = 'root') {
    const items = fs.readdirSync(dir, { withFileTypes: true });
    
    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      
      // 排除指定目录
      if (config.excludeDirs.includes(item.name)) continue;
      
      // 如果 showDirs 不为空，则只显示指定目录
      if (config.showDirs.length > 0 && !config.showDirs.includes(item.name) && item.isDirectory()) {
        continue;
      }
      
      if (item.isDirectory()) {
        walk(fullPath, item.name);
      } else {
        const ext = path.extname(item.name).toLowerCase();
        if (ext === '.md' || ext === '.mdx') {
          const slug = item.name.replace(/\.mdx?$/, '');
          const title = extractTitle(fs.readFileSync(fullPath, 'utf-8'), slug);
          
          docs.push({
            title,
            slug,
            category,
            path: fullPath.replace(basePath + '/', '')
          });
        }
      }
    }
  }
  
  walk(basePath);
  return docs;
}

function extractTitle(content: string, fallback: string): string {
  const match = content.match(/^#\s+(.+)$/m);
  return match ? match[1].trim() : fallback;
}

const config = getConfig();
const docs = getAllDocs(config);

// Group by category
const grouped = docs.reduce((acc, doc) => {
  const cat = doc.category || 'uncategorized';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(doc);
  return acc;
}, {} as Record<string, DocEntry[]>);

const categories = Object.keys(grouped).sort();
---

<Layout title={config.title || '知识库'}>
  <!-- Hero -->
  <div class="hero-card" style="text-align: left; padding: 32px;">
    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
      <span style="font-size: 32px;">📚</span>
      <div>
        <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 4px;">{config.title || '知识库'}</h1>
        <p style="color: var(--text-secondary); font-size: 15px;">共 {docs.length} 篇文档</p>
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="search-box">
    <span class="search-icon">🔍</span>
    <input 
      type="text" 
      id="search-input"
      class="search-input"
      placeholder="搜索文档..."
    />
  </div>

  <!-- Categories -->
  {categories.map(category => (
    <div class="content-card" style="margin-bottom: 20px;">
      <div style="padding: 16px 20px; border-bottom: 1px solid var(--apple-border); display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 18px;">📁</span>
        <span style="font-weight: 600; font-size: 15px;">{category}</span>
        <span style="color: var(--text-secondary); font-size: 13px; margin-left: auto;">
          {grouped[category].length} 篇
        </span>
      </div>
      <div>
        {grouped[category].map(doc => (
          <a 
            href={`/knowledge/${doc.path.replace(/\\/g, '/').replace(/\.mdx?$/, '')}`}
            class="file-item"
          >
            <span style="color: var(--apple-blue);">📄</span>
            <span style="flex: 1;">{doc.title}</span>
            <span style="color: var(--apple-blue); font-size: 13px;">→</span>
          </a>
        ))}
      </div>
    </div>
  ))}

  <!-- Empty state -->
  {docs.length === 0 && (
    <div class="content-card" style="padding: 48px; text-align: center;">
      <div style="font-size: 48px; margin-bottom: 16px;">📭</div>
      <p style="color: var(--text-secondary);">暂无文档</p>
      <p style="color: var(--text-secondary); font-size: 14px; margin-top: 8px;">
        请在 config/site.config.json 中配置知识库路径
      </p>
    </div>
  )}
</Layout>

<script>
  const searchInput = document.getElementById('search-input');
  const fileItems = document.querySelectorAll('.file-item');
  
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    
    fileItems.forEach(item => {
      const text = item.textContent?.toLowerCase() || '';
      if (text.includes(query) || query === '') {
        item.removeAttribute('hidden');
      } else {
        item.setAttribute('hidden', '');
      }
    });
    
    // Hide empty categories
    document.querySelectorAll('.content-card').forEach(card => {
      const visibleItems = card.querySelectorAll('.file-item:not([hidden])');
      if (visibleItems.length === 0) {
        card.setAttribute('hidden', '');
      } else {
        card.removeAttribute('hidden');
      }
    });
  });
</script>
