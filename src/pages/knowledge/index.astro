---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

interface KnowledgeConfig {
  basePath: string;
  showDirs: string[];
  excludeDirs: string[];
  title: string;
}

interface DocEntry {
  title: string;
  slug: string;
  category: string;
  path: string;
  date?: string;
  tags?: string[];
  excerpt?: string;
}

const defaultConfig: KnowledgeConfig = {
  basePath: '/home/ubuntu/my_knowledge',
  showDirs: [],
  excludeDirs: ['.obsidian', '.git', 'Excalidraw', 'Prompt', 'Õģ¼õ╝ŚÕÅĘ'],
  title: 'ń¤źĶ»åÕ║ō'
};

function getConfig(): KnowledgeConfig {
  try {
    const configPath = path.join(process.cwd(), 'config', 'site.config.json');
    if (fs.existsSync(configPath)) {
      const configData = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
      return { ...defaultConfig, ...configData.knowledge };
    }
  } catch (e) {
    console.error('Failed to load config:', e);
  }
  return defaultConfig;
}

function parseFrontmatter(content: string): { metadata: Record<string, any>; body: string } {
  const match = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!match) return { metadata: {}, body: content };

  const yamlStr = match[1];
  const body = match[2];
  const metadata: Record<string, any> = {};

  // Simple YAML parser
  yamlStr.split('\n').forEach(line => {
    const [key, ...valueParts] = line.split(':');
    if (key && valueParts.length > 0) {
      const value = valueParts.join(':').trim();
      
      // Parse arrays like [item1, item2]
      if (value.startsWith('[') && value.endsWith(']')) {
        metadata[key.trim()] = value.slice(1, -1).split(',').map(s => s.trim());
      } else {
        metadata[key.trim()] = value.replace(/^["']|["']$/g, '');
      }
    }
  });

  return { metadata, body };
}

function getExcerpt(body: string, maxLength: number = 120): string {
  // Remove markdown syntax
  const clean = body
    .replace(/^#+\s+/gm, '')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^[-*+]\s+/gm, '')
    .replace(/^\d+\.\s+/gm, '')
    .trim();
  
  return clean.length > maxLength ? clean.slice(0, maxLength) + '...' : clean;
}

function getAllDocs(config: KnowledgeConfig): DocEntry[] {
  const docs: DocEntry[] = [];
  const basePath = config.basePath;
  
  if (!fs.existsSync(basePath)) return docs;
  
  function walk(dir: string, category: string = 'root') {
    const items = fs.readdirSync(dir, { withFileTypes: true });
    
    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      
      if (config.excludeDirs.includes(item.name)) continue;
      
      if (config.showDirs.length > 0 && !config.showDirs.includes(item.name) && item.isDirectory()) {
        continue;
      }
      
      if (item.isDirectory()) {
        walk(fullPath, item.name);
      } else {
        const ext = path.extname(item.name).toLowerCase();
        if (ext === '.md' || ext === '.mdx') {
          const slug = item.name.replace(/\.mdx?$/, '');
          const content = fs.readFileSync(fullPath, 'utf-8');
          const { metadata, body } = parseFrontmatter(content);
          
          const title = metadata.title || extractTitle(body, slug);
          const date = metadata.date;
          const tags = metadata.tags || [];
          
          docs.push({
            title,
            slug,
            category,
            path: fullPath.replace(basePath + '/', ''),
            date,
            tags,
            excerpt: getExcerpt(body)
          });
        }
      }
    }
  }
  
  walk(basePath);
  
  // Sort by date descending
  docs.sort((a, b) => {
    if (a.date && b.date) {
      return new Date(b.date).getTime() - new Date(a.date).getTime();
    }
    return 0;
  });
  
  return docs;
}

function extractTitle(content: string, fallback: string): string {
  const match = content.match(/^#\s+(.+)$/m);
  return match ? match[1].trim() : fallback;
}

const config = getConfig();
const docs = getAllDocs(config);

const grouped = docs.reduce((acc, doc) => {
  const cat = doc.category || doc.path.split('/')[0];
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(doc);
  return acc;
}, {} as Record<string, DocEntry[]>);

const categories = Object.keys(grouped).sort();
---

<Layout title={config.title || 'ń¤źĶ»åÕ║ō'}>
  <!-- Hero -->
  <div class="hero-card" style="text-align: left; padding: 32px;">
    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
      <span style="font-size: 32px;">­¤ōÜ</span>
      <div>
        <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 4px;">{config.title || 'ń¤źĶ»åÕ║ō'}</h1>
        <p style="color: var(--text-secondary); font-size: 15px;">Õģ▒ {docs.length} ń»ćµ¢ćµĪŻ</p>
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="search-box">
    <span class="search-icon">­¤öŹ</span>
    <input 
      type="text" 
      id="search-input"
      class="search-input"
      placeholder="µÉ£ń┤óµ¢ćµĪŻ..."
    />
  </div>

  <!-- Doc Cards -->
  <div style="display: grid; gap: 16px;">
    {docs.map(doc => (
      <a 
        href={`/knowledge/${doc.path.replace(/\\/g, '/').replace(/\.mdx?$/, '')}`}
        class="doc-card"
        data-title={doc.title.toLowerCase()}
        data-tags={doc.tags?.join(' ').toLowerCase() || ''}
        data-excerpt={doc.excerpt || ''}
      >
        <div class="doc-card-inner">
          <div class="doc-card-header">
            <div class="doc-meta">
              {doc.date && (
                <span class="doc-date">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  {doc.date}
                </span>
              )}
              <span class="doc-category">{doc.category || doc.path.split('/')[0]}</span>
            </div>
            {doc.tags && doc.tags.length > 0 && (
              <div class="doc-tags">
                {doc.tags.slice(0, 3).map(tag => (
                  <span class="doc-tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <h3 class="doc-title">{doc.title}</h3>
          {doc.excerpt && (
            <p class="doc-excerpt">{doc.excerpt}</p>
          )}
          <div class="doc-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Empty state -->
  {docs.length === 0 && (
    <div class="content-card" style="padding: 48px; text-align: center;">
      <div style="font-size: 48px; margin-bottom: 16px;">­¤ōŁ</div>
      <p style="color: var(--text-secondary);">µÜéµŚĀµ¢ćµĪŻ</p>
    </div>
  )}
</Layout>

<style>
  .doc-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .doc-card-inner {
    background: var(--bg-primary);
    border-radius: var(--radius-md);
    padding: 20px 24px;
    box-shadow: var(--shadow-sm);
    border: 1px solid transparent;
    transition: all 0.25s ease;
    position: relative;
  }

  .doc-card:hover .doc-card-inner {
    box-shadow: var(--shadow-md);
    border-color: var(--apple-border);
    transform: translateY(-2px);
  }

  .doc-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .doc-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
  }

  .doc-date {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--text-secondary);
  }

  .doc-category {
    color: var(--apple-blue);
    font-weight: 500;
    background: rgba(0, 122, 255, 0.08);
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
  }

  .doc-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .doc-tag {
    background: var(--bg-secondary);
    color: var(--text-secondary);
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 500;
  }

  .doc-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .doc-excerpt {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .doc-arrow {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--apple-border);
    transition: all 0.25s ease;
  }

  .doc-card:hover .doc-arrow {
    color: var(--apple-blue);
    transform: translateY(-50%) translateX(4px);
  }
</style>

<script>
  const searchInput = document.getElementById('search-input');
  const docCards = document.querySelectorAll('.doc-card');
  
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    
    docCards.forEach(card => {
      const title = card.getAttribute('data-title') || '';
      const tags = card.getAttribute('data-tags') || '';
      const excerpt = card.getAttribute('data-excerpt') || '';
      
      const matches = title.includes(query) || tags.includes(query) || excerpt.includes(query);
      
      if (matches || query === '') {
        (card as HTMLElement).style.display = 'block';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  });
</script>
