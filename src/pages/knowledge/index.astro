---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

interface KnowledgeConfig {
  basePath: string;
  showDirs: string[];
  excludeDirs: string[];
  title: string;
}

interface DocEntry {
  title: string;
  slug: string;
  category: string;
  path: string;
  date?: string;
  tags?: string[];
  excerpt?: string;
}

const defaultConfig: KnowledgeConfig = {
  basePath: '/home/ubuntu/my_knowledge',
  showDirs: [],
  excludeDirs: ['.obsidian', '.git', '.claude'],
  title: '知识库'
};

function getConfig(): KnowledgeConfig {
  try {
    const configPath = path.join(process.cwd(), 'config', 'site.config.json');
    if (fs.existsSync(configPath)) {
      const configData = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
      return { ...defaultConfig, ...configData.knowledge };
    }
  } catch (e) {
    console.error('Failed to load config:', e);
  }
  return defaultConfig;
}

function parseFrontmatter(content: string): { metadata: Record<string, any>; body: string } {
  const match = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!match) return { metadata: {}, body: content };

  const yamlStr = match[1];
  const body = match[2];
  const metadata: Record<string, any> = {};

  yamlStr.split('\n').forEach(line => {
    const [key, ...valueParts] = line.split(':');
    if (key && valueParts.length > 0) {
      const value = valueParts.join(':').trim();
      
      if (value.startsWith('[') && value.endsWith(']')) {
        metadata[key.trim()] = value.slice(1, -1).split(',').map(s => s.trim());
      } else {
        metadata[key.trim()] = value.replace(/^["']|["']$/g, '');
      }
    }
  });

  return { metadata, body };
}

function getExcerpt(body: string, maxLength: number = 120): string {
  const clean = body
    .replace(/^#+\s+/gm, '')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/\[\[([^\]|]+)(\|[^\]]+)?\]\]/g, (_, path, alias) => alias ? alias.slice(1) : path.split('/').pop() || path)
    .replace(/^[-*+]\s+/gm, '')
    .replace(/^\d+\.\s+/gm, '')
    .trim();
  
  return clean.length > maxLength ? clean.slice(0, maxLength) + '...' : clean;
}

function getAllDocs(config: KnowledgeConfig): DocEntry[] {
  const docs: DocEntry[] = [];
  const basePath = config.basePath;
  
  if (!fs.existsSync(basePath)) return docs;
  
  function walk(dir: string, category: string = 'root') {
    const items = fs.readdirSync(dir, { withFileTypes: true });
    
    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      
      // Skip excluded dirs
      if (config.excludeDirs.includes(item.name)) continue;
      
      // Skip README and index files in display
      const lowerName = item.name.toLowerCase();
      if (lowerName === 'readme.md' || lowerName === 'index.md' || item.name.startsWith('CLAUDE')) continue;
      
      // If showDirs is set, only show those
      if (config.showDirs.length > 0 && !config.showDirs.includes(item.name) && item.isDirectory()) {
        continue;
      }
      
      if (item.isDirectory()) {
        walk(fullPath, item.name);
      } else {
        const ext = path.extname(item.name).toLowerCase();
        if (ext === '.md' || ext === '.mdx') {
          const slug = item.name.replace(/\.mdx?$/, '');
          const content = fs.readFileSync(fullPath, 'utf-8');
          const { metadata, body } = parseFrontmatter(content);
          
          const title = metadata.title || extractTitle(body, slug);
          const date = metadata.date;
          const tags = metadata.tags || [];
          
          docs.push({
            title,
            slug,
            category,
            path: fullPath.replace(basePath + '/', ''),
            date,
            tags,
            excerpt: getExcerpt(body)
          });
        }
      }
    }
  }
  
  walk(basePath);
  
  // Sort by date descending
  docs.sort((a, b) => {
    if (a.date && b.date) {
      return new Date(b.date).getTime() - new Date(a.date).getTime();
    }
    return 0;
  });
  
  return docs;
}

function extractTitle(content: string, fallback: string): string {
  const match = content.match(/^#\s+(.+)$/m);
  return match ? match[1].trim() : fallback;
}

// Get subdirectories for a given path
function getSubdirs(basePath: string, relativePath: string): string[] {
  const fullPath = path.join(basePath, relativePath);
  if (!fs.existsSync(fullPath)) return [];
  
  const stat = fs.statSync(fullPath);
  if (!stat.isDirectory()) return [];
  
  const items = fs.readdirSync(fullPath, { withFileTypes: true });
  return items
    .filter(item => item.isDirectory())
    .map(item => item.name)
    .filter(name => !name.startsWith('.') && !name.startsWith('assets'))
    .sort();
}

const config = getConfig();
const docs = getAllDocs(config);

// Group by first-level category
const grouped = docs.reduce((acc, doc) => {
  const parts = doc.path.split('/');
  const firstCat = parts[0] || '其他';
  if (!acc[firstCat]) acc[firstCat] = [];
  acc[firstCat].push(doc);
  return acc;
}, {} as Record<string, DocEntry[]>);

const categories = Object.keys(grouped).sort();

// Get subdirectories for display
const categoryMeta: Record<string, { subdirs: string[]; readme?: string }> = {};
for (const cat of categories) {
  const subdirs = getSubdirs(config.basePath, cat);
  const readmePath = path.join(config.basePath, cat, 'README.md');
  categoryMeta[cat] = {
    subdirs,
    readme: fs.existsSync(readmePath) ? fs.readFileSync(readmePath, 'utf-8').slice(0, 200) : undefined
  };
}

// Category icons and colors
const categoryInfo: Record<string, { icon: string; color: string; desc: string }> = {
  '01-学习笔记': { icon: '📖', color: '#007AFF', desc: '系统化的技术学习笔记沉淀' },
  '02-工作日志': { icon: '💼', color: '#34C759', desc: '日常工作记录' },
  '03-面试准备': { icon: '🎯', color: '#FF9500', desc: '求职跳槽相关资料' },
  '04-内容创作': { icon: '🌐', color: '#5856D6', desc: '公众号内容创作素材' },
  '05-资源收藏': { icon: '📊', color: '#FF2D55', desc: '优质内容收藏' },
  '06-绘图': { icon: '📐', color: '#00C7BE', desc: 'Excalidraw 绘图文件' },
};

const categoryIcons: Record<string, string> = {
  'Java后端': '☕',
  'AI与大模型': '🤖',
  '系统架构': '🏗️',
  '工具效率': '🛠️',
  '面试题库': '📝',
  '面经': '💬',
  'AI热点新闻': '📰',
  'AI工具分享': '🔧',
  'Java知识分享': '📚',
  '优质文章': '✨',
  '读书笔记': '📖',
  '架构图': '📊',
  '流程图': '📈',
  '日记': '📅',
  '问题解决': '🔍',
};
---

<Layout title={config.title || '知识库'}>
  <!-- Hero -->
  <div class="hero-card" style="text-align: left; padding: 32px;">
    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
      <span style="font-size: 32px;">📚</span>
      <div>
        <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 4px;">{config.title || '知识库'}</h1>
        <p style="color: var(--text-secondary); font-size: 15px;">共 {docs.length} 篇文档</p>
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="search-box">
    <span class="search-icon">🔍</span>
    <input 
      type="text" 
      id="search-input"
      class="search-input"
      placeholder="搜索文档..."
    />
  </div>

  <!-- Category Sections -->
  {categories.map(category => {
    const info = categoryInfo[category] || { icon: '📁', color: '#8E8E93', desc: '' };
    const meta = categoryMeta[category];
    
    return (
      <div class="category-section" data-category={category.toLowerCase()}>
        <div class="category-header">
          <div class="category-info">
            <span class="category-icon">{info.icon}</span>
            <div>
              <h2 class="category-title">{category}</h2>
              <p class="category-desc">{info.desc}</p>
            </div>
          </div>
          <div class="category-stats">
            <span class="doc-count">{grouped[category].length} 篇</span>
          </div>
        </div>
        
        {/* Subdirectories */}
        {meta.subdirs.length > 0 && (
          <div class="subdirs-container">
            {meta.subdirs.map(subdir => {
              const subIcon = categoryIcons[subdir] || '📁';
              return (
                <a href={`/knowledge/${category}/${subdir}`} class="subdir-badge">
                  <span class="subdir-icon">{subIcon}</span>
                  <span>{subdir}</span>
                </a>
              );
            })}
          </div>
        )}
        
        {/* Doc Cards */}
        <div class="docs-grid">
          {grouped[category].slice(0, 6).map(doc => (
            <a 
              href={`/knowledge/${doc.path.replace(/\\/g, '/').replace(/\.mdx?$/, '')}`}
              class="doc-card"
              data-title={doc.title.toLowerCase()}
              data-tags={doc.tags?.join(' ').toLowerCase() || ''}
              data-excerpt={doc.excerpt || ''}
            >
              <div class="doc-card-inner">
                <div class="doc-card-header">
                  {doc.date && (
                    <span class="doc-date">{doc.date}</span>
                  )}
                  {doc.tags && doc.tags.length > 0 && (
                    <span class="doc-tag">{doc.tags[0]}</span>
                  )}
                </div>
                <h3 class="doc-title">{doc.title}</h3>
                {doc.excerpt && (
                  <p class="doc-excerpt">{doc.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
        
        {grouped[category].length > 6 && (
          <div class="show-more">
            <a href={`/knowledge/${category}`} class="show-more-link">
              查看全部 {grouped[category].length} 篇 →
            </a>
          </div>
        )}
      </div>
    );
  })}

  <!-- Empty state -->
  {docs.length === 0 && (
    <div class="content-card" style="padding: 48px; text-align: center;">
      <div style="font-size: 48px; margin-bottom: 16px;">📭</div>
      <p style="color: var(--text-secondary);">暂无文档</p>
    </div>
  )}
</Layout>

<style>
  .category-section {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: var(--shadow-sm);
  }

  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .category-info {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .category-icon {
    font-size: 32px;
    line-height: 1;
  }

  .category-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .category-desc {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
  }

  .category-stats {
    text-align: right;
  }

  .doc-count {
    font-size: 13px;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    padding: 4px 10px;
    border-radius: 12px;
  }

  .subdirs-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--apple-border);
  }

  .subdir-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--bg-secondary);
    border-radius: 16px;
    text-decoration: none;
    color: var(--text-primary);
    font-size: 13px;
    transition: all 0.2s ease;
  }

  .subdir-badge:hover {
    background: var(--apple-blue);
    color: white;
  }

  .subdir-icon {
    font-size: 14px;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .doc-card {
    text-decoration: none;
    color: inherit;
  }

  .doc-card-inner {
    height: 100%;
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    padding: 16px;
    border: 1px solid var(--apple-border);
    transition: all 0.25s ease;
  }

  .doc-card:hover .doc-card-inner {
    border-color: var(--apple-blue);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .doc-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .doc-date {
    font-size: 12px;
    color: var(--text-secondary);
  }

  .doc-tag {
    font-size: 11px;
    color: var(--apple-blue);
    background: rgba(0, 122, 255, 0.08);
    padding: 2px 8px;
    border-radius: 8px;
  }

  .doc-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .doc-excerpt {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .show-more {
    text-align: center;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--apple-border);
  }

  .show-more-link {
    color: var(--apple-blue);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
  }

  .show-more-link:hover {
    text-decoration: underline;
  }
</style>

<script>
  const searchInput = document.getElementById('search-input');
  const docCards = document.querySelectorAll('.doc-card');
  const categorySections = document.querySelectorAll('.category-section');
  
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    
    categorySections.forEach((sectionEl) => {
      const sectionHTMLElement = sectionEl as HTMLElement;
      const cards = sectionHTMLElement.querySelectorAll('.doc-card');
      let visibleCount = 0;
      
      cards.forEach(card => {
        const title = card.getAttribute('data-title') || '';
        const tags = card.getAttribute('data-tags') || '';
        const excerpt = card.getAttribute('data-excerpt') || '';
        
        const matches = title.includes(query) || tags.includes(query) || excerpt.includes(query);
        
        if (matches || query === '') {
          (card as HTMLElement).style.display = 'block';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
      
      // Hide category if no matches
      if (visibleCount === 0 && query !== '') {
        sectionHTMLElement.style.display = 'none';
      } else {
        sectionHTMLElement.style.display = 'block';
      }
    });
  });
</script>
