---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const knowledgePath = path.join(process.cwd(), 'public', 'content', 'knowledge');
  const paths: { params: { slug: string }; props: { title: string; content: string; breadcrumb: string } }[] = [];

  function walk(dir: string, baseSlug: string = '') {
    if (!fs.existsSync(dir)) return;

    const items = fs.readdirSync(dir, { withFileTypes: true });

    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      const ext = path.extname(item.name).toLowerCase();

      if (item.isDirectory()) {
        walk(fullPath, baseSlug ? `${baseSlug}/${item.name}` : item.name);
      } else if (ext === '.md' || ext === '.mdx') {
        const slug = item.name.replace(/\.mdx?$/, '');
        const fullSlug = baseSlug ? `${baseSlug}/${slug}` : slug;
        const content = fs.readFileSync(fullPath, 'utf-8');
        const titleMatch = content.match(/^#\s+(.+)$/m);
        const title = titleMatch ? titleMatch[1].trim() : slug;

        paths.push({
          params: { slug: fullSlug },
          props: { 
            title, 
            content,
            breadcrumb: baseSlug ? baseSlug.split('/').join(' > ') : 'root'
          }
        });
      }
    }
  }

  walk(knowledgePath);
  return paths;
}

const { title, content, breadcrumb } = Astro.props;

// Simple markdown to HTML conversion
function renderMarkdown(md: string): string {
  return md
    // Headers
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    // Bold & Italic
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // Code blocks
    .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code class="language-$1">$2</code></pre>')
    // Inline code
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    // Links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" style="color: var(--cyber-cyan);">$1</a>')
    // Lists
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
    // Blockquotes
    .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
    // Paragraphs
    .replace(/\n\n/g, '</p><p>')
    // Line breaks
    .replace(/\n/g, '<br />');
}

const htmlContent = renderMarkdown(content);
---

<Layout title={title}>
  <div class="max-w-4xl mx-auto">
    <!-- Breadcrumb -->
    <div class="terminal-window mt-4 p-4">
      <div class="flex items-center gap-2 text-sm opacity-70">
        <a href="/knowledge" style="color: var(--cyber-cyan);">📚 knowledge</a>
        <span>/</span>
        <span>{breadcrumb}</span>
        <span>/</span>
        <span class="glow-green" style="color: var(--cyber-green);">{title}</span>
      </div>
    </div>

    <!-- Document -->
    <article class="terminal-window mt-4">
      <div class="terminal-header">
        <div class="terminal-dot dot-red"></div>
        <div class="terminal-dot dot-yellow"></div>
        <div class="terminal-dot dot-green"></div>
        <span class="ml-4 text-sm opacity-70">{title}</span>
      </div>
      <div class="terminal-body p-6">
        <div class="markdown-content" set:html={htmlContent} />
      </div>
    </article>

    <!-- Navigation -->
    <div class="flex justify-between mt-6">
      <a href="/knowledge" class="btn-cyber">
        ← Back to Knowledge Base
      </a>
      <a href="/chat" class="btn-cyber" style="border-color: var(--cyber-purple); color: var(--cyber-purple);">
        Ask AI about this →
      </a>
    </div>
  </div>
</Layout>

<style>
  .markdown-content {
    line-height: 1.8;
  }
  
  .markdown-content :global(h1),
  .markdown-content :global(h2),
  .markdown-content :global(h3) {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }
  
  .markdown-content :global(pre) {
    background: rgba(0, 0, 0, 0.5);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1em 0;
  }
  
  .markdown-content :global(blockquote) {
    border-left: 3px solid var(--cyber-purple);
    padding-left: 1em;
    margin: 1em 0;
    color: var(--cyber-purple);
  }
</style>
