---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const basePath = '/home/ubuntu/my_knowledge';
  const showDirs = ['01-学习笔记', '02-工作日志', '04-内容创作', '05-资源收藏', '06-绘图'];
  const excludeDirs = ['.obsidian', '.git', '.claude', '00-规范'];
  
  const paths = [];

  function walk(dir: string, baseSlug: string = '') {
    if (!fs.existsSync(dir)) return;

    const items = fs.readdirSync(dir, { withFileTypes: true });

    for (const item of items) {
      const fullPath = path.join(dir, item.name);
      
      if (excludeDirs.includes(item.name)) continue;
      
      if (showDirs.length > 0 && !showDirs.includes(item.name) && item.isDirectory()) {
        continue;
      }

      if (item.isDirectory()) {
        walk(fullPath, baseSlug ? `${baseSlug}/${item.name}` : item.name);
      } else {
        const lowerName = item.name.toLowerCase();
        if (lowerName === 'readme.md' || lowerName === 'index.md') continue;
        
        const ext = path.extname(item.name).toLowerCase();
        if (ext === '.md' || ext === '.mdx') {
          const slug = item.name.replace(/\.mdx?$/, '');
          const fullSlug = baseSlug ? `${baseSlug}/${slug}` : slug;
          const content = fs.readFileSync(fullPath, 'utf-8');
          
          // Parse frontmatter inline
          const match = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
          let metadata: Record<string, any> = {};
          let body = content;
          
          if (match) {
            const yamlStr = match[1];
            body = match[2];
            
            yamlStr.split('\n').forEach(line => {
              const [key, ...valueParts] = line.split(':');
              if (key && valueParts.length > 0) {
                const value = valueParts.join(':').trim();
                if (value.startsWith('[') && value.endsWith(']')) {
                  metadata[key.trim()] = value.slice(1, -1).split(',').map(s => s.trim());
                } else {
                  metadata[key.trim()] = value.replace(/^["']|["']$/g, '');
                }
              }
            });
          }
          
          // Extract title
          const titleMatch = body.match(/^#\s+(.+)$/m);
          const title = metadata.title || (titleMatch ? titleMatch[1].trim() : slug);

          // Simple markdown to HTML conversion
          const htmlContent = body
            .replace(/^### (.+)$/gm, '<h3>$1</h3>')
            .replace(/^## (.+)$/gm, '<h2>$1</h2>')
            .replace(/^# (.+)$/gm, '<h1>$1</h1>')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>')
            .replace(/`([^`]+)`/g, '<code>$1</code>')
            .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" style="color: var(--apple-blue);">$1</a>')
            .replace(/^- (.+)$/gm, '<li>$1</li>')
            .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
            .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
            .replace(/\n\n/g, '</p><p>')
            .replace(/\n/g, '<br />');

          paths.push({
            params: { slug: fullSlug },
            props: { 
              title, 
              content: body,
              htmlContent,
              breadcrumb: baseSlug ? baseSlug.split('/').join(' > ') : 'root',
              metadata
            }
          });
        }
      }
    }
  }

  walk(basePath);
  return paths;
}

const { title, content, htmlContent, breadcrumb, metadata } = Astro.props;
---

<Layout title={title}>
  <div style="max-width: 800px; margin: 0 auto;">
    <div style="margin-bottom: 24px;">
      <a href="/knowledge" style="color: var(--apple-blue); text-decoration: none; font-size: 14px; display: inline-flex; align-items: center; gap: 4px;">
        ← 返回知识库
      </a>
    </div>

    <div class="content-card" style="overflow: hidden;">
      <div style="padding: 28px 32px; border-bottom: 1px solid var(--apple-border);">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap;">
          {metadata.date && (
            <span style="display: flex; align-items: center; gap: 4px; color: var(--text-secondary); font-size: 13px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              {metadata.date}
            </span>
          )}
          {metadata.category && (
            <span style="background: rgba(0, 122, 255, 0.1); color: var(--apple-blue); padding: 4px 12px; border-radius: 16px; font-size: 12px; font-weight: 500;">
              {metadata.category}
            </span>
          )}
          {metadata.status && (
            <span style={`background: ${metadata.status === '草稿' ? 'rgba(255, 149, 0, 0.1)' : 'rgba(52, 199, 89, 0.1)'}; color: ${metadata.status === '草稿' ? 'var(--apple-warning)' : 'var(--apple-success)'}; padding: 4px 12px; border-radius: 16px; font-size: 12px; font-weight: 500;`}>
              {metadata.status}
            </span>
          )}
        </div>

        <h1 style="font-size: 28px; font-weight: 700; line-height: 1.3; margin-bottom: 16px; letter-spacing: -0.5px;">
          {title}
        </h1>

        {metadata.tags && metadata.tags.length > 0 && (
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            {metadata.tags.map((tag: string) => (
              <span style="background: var(--bg-secondary); color: var(--text-secondary); padding: 4px 10px; border-radius: 8px; font-size: 12px;">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>

      <div style="padding: 32px;">
        <div class="markdown" set:html={htmlContent} />
      </div>

      <div style="padding: 20px 32px; border-top: 1px solid var(--apple-border); background: var(--bg-tertiary);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <a href="/knowledge" class="btn btn-secondary" style="font-size: 14px;">
            ← 返回列表
          </a>
          <a href="/chat" class="btn btn-primary" style="font-size: 14px;">
            💬 询问 AI
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .markdown {
    line-height: 1.8;
    font-size: 16px;
  }
  
  .markdown :global(h1) {
    font-size: 26px;
    font-weight: 700;
    margin-top: 32px;
    margin-bottom: 16px;
  }
  
  .markdown :global(h2) {
    font-size: 20px;
    font-weight: 600;
    margin-top: 28px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--apple-border);
  }
  
  .markdown :global(h3) {
    font-size: 17px;
    font-weight: 600;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  
  .markdown :global(p) {
    margin-bottom: 16px;
  }
  
  .markdown :global(ul), .markdown :global(ol) {
    padding-left: 24px;
    margin-bottom: 16px;
  }
  
  .markdown :global(li) {
    margin-bottom: 8px;
  }
  
  .markdown :global(pre) {
    background: var(--bg-secondary);
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 16px 0;
  }
  
  .markdown :global(code) {
    font-family: 'SF Mono', Monaco, Consolas, monospace;
    font-size: 14px;
    background: var(--bg-secondary);
    padding: 2px 6px;
    border-radius: 4px;
  }
  
  .markdown :global(pre code) {
    background: none;
    padding: 0;
  }
  
  .markdown :global(blockquote) {
    border-left: 4px solid var(--apple-blue);
    padding-left: 16px;
    margin: 16px 0;
    color: var(--text-secondary);
  }
</style>
