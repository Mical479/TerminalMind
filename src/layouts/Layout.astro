---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'TerminalMind', 
  description = 'Knowledge Base & Interview Playground' 
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | TerminalMind</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Header -->
    <header class="header">
      <div class="header-content">
        <a href="/" class="logo">TerminalMind</a>
        
        <nav class="nav">
          <a 
            href="/" 
            class:list={["nav-link", { active: currentPath === "/" }]}
          >
            首页
          </a>
          <a 
            href="/knowledge" 
            class:list={["nav-link", { active: currentPath.startsWith("/knowledge") }]}
          >
            知识库
          </a>
          <a 
            href="/interview" 
            class:list={["nav-link", { active: currentPath.startsWith("/interview") }]}
          >
            面试题
          </a>
          <a 
            href="/chat" 
            class:list={["nav-link", { active: currentPath === "/chat" }]}
          >
            AI 对话
          </a>
        </nav>

        <div class="text-sm" style="color: var(--text-secondary);">
          <span id="time"></span>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <p>TerminalMind v1.0 | Powered by OpenClaw AI</p>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  function updateTime() {
    const now = new Date();
    const timeStr = now.toLocaleString('zh-CN', { 
      hour12: false, 
      hour: '2-digit', 
      minute: '2-digit'
    });
    const timeEl = document.getElementById('time');
    if (timeEl) timeEl.textContent = timeStr;
  }
  updateTime();
  setInterval(updateTime, 60000);
</script>
