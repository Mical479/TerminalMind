# TerminalMind Environment Variables
# Copy this file to .env and fill in your values

# AI Configuration
OPENCLAW_API_KEY=your-openclaw-api-key-here
OPENCLAW_ENDPOINT=http://localhost:8250/api/chat

# Authentication (for htpasswd)
ADMIN_USER=admin
ADMIN_PASS=your-password-here

# Site URL (for production)
SITE_URL=https://your-domain.com
